--------------------------------------------------------------------------------
-- Port State Model
--------------------------------------------------------------------------------
local function getPortState(port)
  state.ports[port] = state.ports[port] or {
    enabled  = true,
    link     = false,
    memberOf = nil,
    poe      = nil,
    rlinkx   = nil,
    speed    = nil,
    lastValidSpeed = nil,
    speedPending   = false
  }
  return state.ports[port]
end

--------------------------------------------------------------------------------
-- Light/Dark Theme
--------------------------------------------------------------------------------
local function getThemeColors()
  return {
    groupboxFill     = state.darkMode and {12, 21, 42}         or {240, 245, 255, 255},
    textColor        = state.darkMode and {180, 255, 255}      or {75, 0, 0, 255},
    textboxColor     = state.darkMode and {0, 0, 0}            or {0, 0, 0},
    textboxBg        = state.darkMode and {40, 40, 60, 180}    or {215, 200, 180, 255},
    buttonColor      = state.darkMode and {0, 150, 255}        or {255, 105, 0, 255},
    buttonAltColor   = state.darkMode and {0, 150, 255}        or {255, 105, 0, 255},
    buttonOffColor   = state.darkMode and {60, 60, 60}         or {200, 200, 200, 255},
    indicatorFill    = state.darkMode and {20, 24, 40, 230}    or {240, 245, 255, 255},
    strokeColor      = state.darkMode and {60, 60, 60}         or {120, 120, 120, 255},
    rectangleFill    = state.darkMode and {30, 40, 60, 220}    or {240, 245, 255, 255},
    labelGray        = state.darkMode and {200, 200, 200}      or {230, 230, 230, 255}
  }
end

--------------------------------------------------------------------------------
--------------------------------------------------------------------------------
-- Port UI Renderer (UI ONLY)
--------------------------------------------------------------------------------
--------------------------------------------------------------------------------
function renderPortUI(port)
  local p = getPortState(port)

  --------------------------------------------------------------------------
  -- Link state
  --------------------------------------------------------------------------
  local linkCtrl = Controls["port"..port]
  if linkCtrl then
    linkCtrl.Boolean = (p.link == true)
  end

  --------------------------------------------------------------------------
  -- Port Enabled / Disabled
  --------------------------------------------------------------------------
  local enableToggle = Controls["port_enable_toggle_"..port]
  if enableToggle then
    enableToggle.Boolean = (p.enabled == true)
  end

  --------------------------------------------------------------------------
  -- Group / Trunk color
  --------------------------------------------------------------------------
  local groupCtrl = Controls["port_group_color_"..port]
  if groupCtrl then
    local color = GROUP_COLORS[p.memberOf]
    if color then
      local r, g, b = table.unpack(color)
      groupCtrl.Color = string.format("#%02X%02X%02X", r, g, b)
    else
      groupCtrl.Color = "#00000000"
    end
    groupCtrl.String = p.memberOf or ""
  end

  --------------------------------------------------------------------------
  -- PoE indication
  --------------------------------------------------------------------------
  local poeLabel = Controls["indication"..port]
  if poeLabel then
    poeLabel.String = p.poe or ""
  end

  local poeBox = Controls["poe_color_"..port]
  if poeBox then
    local map = {
      sourcing = "#FF8000", -- orange
      enabled  = "#FFD700", -- yellow
      disabled = "#444444", -- dark gray
    }
    poeBox.Color = map[(p.poe or ""):lower()] or "#00000000"
    poeBox.String = ""
  end

  --------------------------------------------------------------------------
  -- PoE
  --------------------------------------------------------------------------
-- PoE enabled toggle (port settings page)
  local poeToggle = Controls["port_poe_toggle_" .. port]
  if poeToggle then
    -- Toggle state (admin)
    poeToggle.Boolean = (p.poeEnabled == true)

    -- Visual state follows PoE indication (same logic as first page)
    local map = {
      sourcing = "#FF8000", -- orange
      enabled  = "#FFD700", -- yellow
      disabled = "#444444", -- dark gray
    }

    poeToggle.Color  = map[(p.poe or ""):lower()] or "#00000000"
    poeToggle.Legend = (p.poe == "sourcing") and "⚡" or ""
  end

  --------------------------------------------------------------------------
  -- RLinkX
  --------------------------------------------------------------------------
  local rlink = Controls["rlinkx_bar_"..port]
  if rlink then
    local map = {
      enabled  = "#00B2FF",
      disabled = "#999999",
    }
    rlink.Color = map[p.rlinkx] or "#00000000"
    rlink.String = ""
  end

  local rlinkToggle = Controls["port_rlinkx_toggle_"..port]
  if rlinkToggle then
    rlinkToggle.Boolean = (p.rlinkx == "enabled")
  end

  --------------------------------------------------------------------------
  -- Speed
  --------------------------------------------------------------------------
  local speedCtrl = Controls["port_speed_dropdown_"..port]
  if speedCtrl and p.speed then
    speedCtrl.String = p.speed
  end
end

--------------------------------------------------------------------------------
-- Compute page size for the "Controls" page
--------------------------------------------------------------------------------
local function getControlsPageSize(portCount)
  local columns         = math.ceil(portCount / 2)
  local btnW, btnH      = 66, 38
  local colSpacing      = 8
  local leftRightMargin = 40
  local totalPortsW = columns * btnW + (columns - 1)*colSpacing
  local totalW = totalPortsW + leftRightMargin*2
  local totalH = 300          -- page height

  return totalW, totalH
end

--------------------------------------------------------------------------------
-- Basic Auth
--------------------------------------------------------------------------------
function MergeTables(a, b)
  local result = {}
  for k, v in pairs(a) do result[k] = v end
  for k, v in pairs(b) do result[k] = v end
  return result
end

local function getAuthHeaders()
  local user = Controls["auth_username"] and Controls["auth_username"].String or ""
  local pass = Controls["auth_password"] and Controls["auth_password"].String or ""
  if user == "" or pass == "" then return {} end
  local token = Crypto.Base64Encode(user .. ":" .. pass)
  return { ["Authorization"] = "Basic " .. token }
end

--------------------------------------------------------------------------------
-- WebSocket Setup
--------------------------------------------------------------------------------
local function subscribeAllPorts()
  if not state.ws then
    return
  end

  -- Per-port subscriptions
  for i = 1, state.portCount do  -- loop only as many ports as the chosen model has

    -- Link state
    local linkMsg = string.format(
      '{"subscription":{"path":"/ports/port/%d/link_state","action":"add","method":"changes"}}',
      i
    )
    state.ws:Write(linkMsg)

    -- Member of (Group / Trunk)
    local memberMsg = string.format(
      '{"subscription":{"path":"/ports/port/%d/member_of","action":"add","method":"changes"}}',
      i
    )
    state.ws:Write(memberMsg)

    -- PoE indication
    local indMsg = string.format(
      '{"subscription":{"path":"/poe/ports/%d/indication","action":"add","method":"changes"}}',
      i
    )
    state.ws:Write(indMsg)

    -- PoE enabled / disabled (toggle on Port Settings page)
    local poeEnabledMsg = string.format(
      '{"subscription":{"path":"/poe/ports/%d/enabled","action":"add","method":"changes"}}',
      i
    )
    state.ws:Write(poeEnabledMsg)

    -- RLinkX
    local rlinkxMsg = string.format(
      '{"subscription":{"path":"/ports/port/%d/rlinkx","action":"add","method":"changes"}}',
      i
    )
    state.ws:Write(rlinkxMsg)

    -- Port legend
    local legendMsg = string.format(
      '{"subscription":{"path":"/ports/port/%d/legend","action":"add","method":"changes"}}',
      i
    )
    state.ws:Write(legendMsg)

    -- Port enabled / disabled
    local enabledMsg = string.format(
      '{"subscription":{"path":"/ports/port/%d/enabled","action":"add","method":"changes"}}',
      i
    )
    state.ws:Write(enabledMsg)

    -- Link speed
    local speedMsg = string.format(
      '{"subscription":{"path":"/ports/port/%d/link_speed","action":"add","method":"changes"}}',
      i
    )
    state.ws:Write(speedMsg)

  end

  -- Device-level subscriptions
  local devMsg = '{"subscription":{"path":"/device/name","action":"add","method":"changes"}}'
  state.ws:Write(devMsg)

  local descMsg = '{"subscription":{"path":"/device/description","action":"add","method":"changes"}}'
  state.ws:Write(descMsg)

  local actualIPMsg = '{"subscription":{"path":"/device/actual_ip/ip_address","action":"add","method":"changes"}}'
  state.ws:Write(actualIPMsg)

  local prefixLengthMsg = '{"subscription":{"path":"/device/actual_ip/prefix_length","action":"add","method":"changes"}}'
  state.ws:Write(prefixLengthMsg)

  local IPmodeMsg = '{"subscription":{"path":"/ip_settings/mode","action":"add","method":"changes"}}'
  state.ws:Write(IPmodeMsg)

  local macMsg = '{"subscription":{"path":"/device/mac_address","action":"add","method":"changes"}}'
  state.ws:Write(macMsg)

  local firmMsg = '{"subscription":{"path":"/device/firmware/active","action":"add","method":"changes"}}'
  state.ws:Write(firmMsg)
end


-- For group page
-- NOTE: UI currently supports groups 1–20 only
local MAX_GROUPS = 20

function subscribeAllGroups()
  if not state.ws then return end

  for i = 1, MAX_GROUPS do
    -- Subscribe to name
    local nameMsg = string.format('{"subscription":{"path":"/groups/group/%d/name","action":"add","method":"changes"}}', i)
    state.ws:Write(nameMsg)

    -- Subscribe to group_id
    local idMsg = string.format('{"subscription":{"path":"/groups/group/%d/group_id","action":"add","method":"changes"}}', i)
    state.ws:Write(idMsg)
  end
end

local function openWS(ip)
  state.baseIP = ip

  if state.ws then
    state.ws:Close()
    state.ws = nil
  end

  state.ws = WebSocket.New()

  state.ws.Connected = function()
    log("WebSocket Connected => subscribeAllPorts()")

    updateAuthStatus("Authenticated", "#00A000")  -- green status

    subscribeAllPorts()
    subscribeAllGroups()
    SetDeviceStatus("online")

    syncPoeEnabledState()   -- <<< ADD THIS LINE
  end

  state.ws.Data = function(_, data)
    log("Data: " .. tostring(data))
    if data:find('"api_notification"') then
      parseNotification(data)
    end
  end

  state.ws.Error = function(_, err)
    log("WebSocket Error: " .. (err or "none"))
	if err and err:find("unauthorized") then
	  updateAuthStatus("Auth failed", "#C80000")
	end
    SetDeviceStatus("offline")
    Timer.CallAfter(function() openWS(state.baseIP) end, 5)
  end

  state.ws.Closed = function()
    log("WebSocket Closed")
    SetDeviceStatus("offline")
    Timer.CallAfter(function() openWS(state.baseIP) end, 5)
  end

  -- Get credentials from UI
  local user = Controls["auth_username"] and Controls["auth_username"].String or ""
  local pass = Controls["auth_password"] and Controls["auth_password"].String or ""
  local headers = {}

  if user ~= "" and pass ~= "" then
    local token = Crypto.Base64Encode(user .. ":" .. pass)
    headers["Authorization"] = "Basic " .. token
  end

  log("Connecting => ws://" .. ip .. "/api/ws on port 80")
  state.ws:Connect("ws", ip, "api/ws", 80, nil, headers)
end

--------------------------------------------------------------------------------
-- IP Info
--------------------------------------------------------------------------------
local function updateIPinfo()      -- format to: "192.168.10.25/16 (static)"
  local ip    = (state.currentIP    ~= "" and state.currentIP)    or "???"
  local pref  = (state.prefixLength ~= "" and state.prefixLength) or "??"
  local mode  = (state.ipMode       ~= "" and state.ipMode)       or "???"
  local combined = string.format("%s/%s (%s)", ip, pref, mode)
  if Controls["ip_info"] then
    Controls["ip_info"].String = combined
  end
end

--------------------------------------------------------------------------------
-- Device name and device description
--------------------------------------------------------------------------------
local function formatDeviceName(rawName)                      -- Format Device Name/Description
  if #rawName > 32 then                                       -- more than 32 characters, insert a newline
    local part1 = string.sub(rawName, 1, 32)
    local part2 = string.sub(rawName, 33)
    return part1 .. "\n" .. part2
  else
    return rawName
  end
end
local function formatDeviceDesc(rawDesc)
  if #rawDesc > 32 then
    local part1 = string.sub(rawDesc, 1, 32)
    local part2 = string.sub(rawDesc, 33)
    return part1 .. "\n" .. part2
  else
    return rawDesc
  end
end

--------------------------------------------------------------------------------
-- mac address and firmware
--------------------------------------------------------------------------------
local function updateMac_Firmware()    -- To format to: "d0:69:9e:00:00:00 - 1.6.0"
  local mac = state.macAddress ~= "" and state.macAddress or "??:??:??:??:??:??"
  local firm = state.firmwareVersion ~= "" and state.firmwareVersion or "?.?.?"
  local combined = string.format("%s  –  %s", mac, firm)
  if Controls["mac_firmware"] then
    Controls["mac_firmware"].String = combined
  end
end

--------------------------------------------------------------------------------
-- updateAuthStatus
--------------------------------------------------------------------------------
function updateAuthStatus(text, color)
  local ctrl = Controls["auth_status"]
  if not ctrl then return end

  ctrl.String = text
  ctrl.Color = (text ~= "") and (color or "#800000") or "#00000000"
end

--------------------------------------------------------------------------------
-- For Groups over 20
--------------------------------------------------------------------------------
function layoutGroupBlock(index)
  local baseX, baseY = 0, 0
  local paddingX, paddingY = 10, 10
  local blockW, blockH = 100, 50
  local gridCols = 4

  if index <= 20 then
    local col = (index - 1) % gridCols
    local row = math.floor((index - 1) / gridCols)
    local x = baseX + col * (blockW + paddingX)
    local y = baseY + row * (blockH + paddingY)
    return x, y
  else
    local colOffset = index - 21
    local x = baseX + gridCols * (blockW + paddingX) + colOffset * (blockW + paddingX)
    local y = baseY
    return x, y
  end
end

-- Draw visible groups (1–20)
function createGroupLayout()
  for groupId = 1, 20 do
    if state.groupMeta[groupId] then
      local x, y = layoutGroupBlock(groupId)
      -- Drawing intentionally disabled
    end
  end
end

--------------------------------------------------------------------------------
-- PARSER : WebSocket Notifications
--------------------------------------------------------------------------------
local function extractPath(raw)
  return raw:match('"path"%s*:%s*"([^"]+)"')
end

local function extractString(raw)
  return raw:match('"new_value"%s*:%s*"([^"]+)"')
end

local function extractNumber(raw)
  return raw:match('"new_value"%s*:%s*(%d+)')
end

local function extractBool(raw)
  return raw:match('"new_value"%s*:%s*(%a+)')
end

--------------------------------------------------------------------------------
-- Device handlers
--------------------------------------------------------------------------------
local function handleDevicePath(path, raw)
  if path == "/device/name" then
    local v = extractString(raw)
    if v then Controls["device_name"].String = formatDeviceName(v) end
    return true
  end

  if path == "/device/description" then
    local v = extractString(raw)
    if v then Controls["device_description"].String = formatDeviceDesc(v) end
    return true
  end

  if path == "/device/mac_address" then
    local v = extractString(raw)
    if v then
      state.macAddress = v
      updateMac_Firmware()
    end
    return true
  end

  if path == "/device/firmware/active" then
    local v = extractString(raw)
    if v then
      state.firmwareVersion = v
      updateMac_Firmware()
    end
    return true
  end

  if path == "/device/actual_ip/ip_address" then
    local v = extractString(raw)
    if v then
      state.currentIP = v
      updateIPinfo()
    end
    return true
  end

  if path == "/device/actual_ip/prefix_length" then
    local v = extractNumber(raw)
    if v then
      state.prefixLength = v
      updateIPinfo()
    end
    return true
  end

  if path == "/ip_settings/mode" then
    local v = extractString(raw)
    if v then
      state.ipMode = v
      updateIPinfo()
    end
    return true
  end

  return false
end

--------------------------------------------------------------------------------
-- Group handlers
--------------------------------------------------------------------------------
local function handleGroupPath(path, raw)
  local gid, field = path:match("^/groups/group/(%d+)/(.+)$")
  if not gid then return false end
  gid = tonumber(gid)

  if field == "name" then
    local name = extractString(raw)
    if name then
      state.groupNames[gid] = name
      SetGroupLabel(gid, name)
    end
    return true
  end

  if field == "group_id" then
    local v = extractNumber(raw)
    if v then
      state.groupMeta = state.groupMeta or {}
      state.groupMeta[gid] = state.groupMeta[gid] or {}
      state.groupMeta[gid].id = tonumber(v)

      updateGroupUI(gid)
      SetGroupLabel(gid, state.groupNames[gid] or ("Group " .. gid))
      createGroupLayout()
    end
    return true
  end

  return false
end

--------------------------------------------------------------------------------
-- Port handlers (STATE ONLY)
--------------------------------------------------------------------------------
local function handlePortPath(path, raw)
  local port = path:match("/ports/port/(%d+)/") or path:match("/poe/ports/(%d+)/")
  if not port then return false end
  port = tonumber(port)

  ---------------------------------------------------------------------------
  -- Port enabled
  ---------------------------------------------------------------------------
  if path == ("/ports/port/" .. port .. "/enabled") then
    local v = extractBool(raw)
    if v then
      SetPortEnabled(port, v == "true")
    end
    return true
  end

  ---------------------------------------------------------------------------
  -- Legend
  ---------------------------------------------------------------------------
  if path == ("/ports/port/" .. port .. "/legend") then
    local v = extractString(raw)
    if v then
      local display = Controls["port_legend_display_" .. port]
      local edit    = Controls["port_legend_edit_" .. port]

      if display then
        display.String = (#v > 8) and (v:sub(1,8) .. " \n" .. v:sub(9)) or v
      end
      if edit then
        edit.String = v
      end
    end
    return true
  end

  ---------------------------------------------------------------------------
  -- Link state
  ---------------------------------------------------------------------------
  if path == ("/ports/port/" .. port .. "/link_state") then
    local v = extractString(raw)
    if v then
      SetPortLink(port, v ~= "down" and v ~= "unknown")
    end
    return true
  end

  ---------------------------------------------------------------------------
  -- Member of (group / trunk)
  ---------------------------------------------------------------------------
  if path == ("/ports/port/" .. port .. "/member_of") then
    local obj = raw:match('"new_value"%s*:%s*{(.-)}')
    if obj then
      local t  = obj:match('"type"%s*:%s*"([^"]+)"')
      local id = obj:match('"id"%s*:%s*(%d+)')
      if t and id then
        SetPortMemberOf(
          port,
          t == "trunk" and ("Trunk: " .. id) or ("Group: " .. id)
        )
      end
    else
      local v = extractString(raw)
      if v then
        SetPortMemberOf(port, v)
      end
    end
    return true
  end

  ---------------------------------------------------------------------------
  -- PoE indication (read-only state from switch)
  ---------------------------------------------------------------------------
  if path == ("/poe/ports/" .. port .. "/indication") then
    local v = extractString(raw)
    if v then
      SetPortIndication(port, v)
    end
    return true
  end

  ---------------------------------------------------------------------------
  -- PoE enabled
  ---------------------------------------------------------------------------
  if path == ("/poe/ports/" .. port .. "/enabled") then
    local v = extractBool(raw)
    if v then
      SetPortPoeEnabled(port, v == "true")
    end
    return true
  end

  ---------------------------------------------------------------------------
  -- RLinkX
  ---------------------------------------------------------------------------
  if path == ("/ports/port/" .. port .. "/rlinkx") then
    local obj = raw:match('"new_value"%s*:%s*{(.-)}')
    if obj then
      local b = obj:match('"enabled"%s*:%s*(%a+)')
      if b then
        SetPortRlinkx(port, b == "true" and "enabled" or "disabled")
      end
    end
    return true
  end

  ---------------------------------------------------------------------------
  -- Link speed
  ---------------------------------------------------------------------------
  if path:find("/link_speed") then
    local mode  = raw:match('"mode"%s*:%s*"([^"]+)"')
    local speed = raw:match('"speed"%s*:%s*%[%"([^"]+)"%]')

    if mode == "auto" then
      -- if "all" => show Auto
      if speed == "all" or not speed then
        SetPortSpeed(port, "Auto")
      else

        SetPortSpeed(port, speed)
      end

    elseif mode == "fixed" and speed then

      SetPortSpeed(port, speed)
    end

    return true
  end

  return false
end

--------------------------------------------------------------------------------
-- Final router
--------------------------------------------------------------------------------
function parseNotification(raw)
  log("parseNotification => " .. raw)

  local path = extractPath(raw)
  if not path then return end

  if handleDevicePath(path, raw) then return end
  if handleGroupPath(path, raw)  then return end
  if handlePortPath(path, raw)   then return end
end

--------------------------------------------------------------------------------
-- Set Port State (STATE ONLY)
--------------------------------------------------------------------------------
function SetPortLink(port, isOn)
  local p = getPortState(port)
  p.link = isOn
  renderPortUI(port)
end

function SetPortEnabled(port, enabled)
  local p = getPortState(port)
  p.enabled = enabled
  renderPortUI(port)
end

function SetPortMemberOf(port, textVal)
  local p = getPortState(port)
  p.memberOf = textVal
  renderPortUI(port)
end

function SetPortIndication(port, textVal)
  local p = getPortState(port)
  p.poe = textVal
  renderPortUI(port)
end

function SetPortRlinkx(port, stateString)
  local p = getPortState(port)
  p.rlinkx = stateString
  renderPortUI(port)
end

function SetPortSpeed(port, label)
  local p = getPortState(port)

  p.speed = SPEED_UI_MAP[label] or label
  p.lastValidSpeed = p.speed
  p.speedPending = false

  renderPortUI(port)
end

function SetPortPoeEnabled(port, enabled)
  local p = getPortState(port)
  p.poeEnabled = enabled
  renderPortUI(port)
end

--------------------------------------------------------------------------------
-- Initial PoE enabled state sync (REST snapshot)
--------------------------------------------------------------------------------
local function syncPoeEnabledState()
  for p = 1, state.portCount do
    local url = string.format(
      "http://%s/api/poe/ports/%d/enabled",
      state.baseIP,
      p
    )

    HttpClient.Get{
      Url     = url,
      Headers = MergeTables(
        { ["Content-Type"] = "application/json" },
        getAuthHeaders()
      ),
      EventHandler = function(body, code, err)
        if code == 200 and body ~= nil then
          SetPortPoeEnabled(p, body == "true")
        end
      end
    }
  end
end

-- device
function SetDeviceStatus(state)
  local ctrl = Controls["device_status"]
  if not ctrl then return end

  if state == "online" then
    if offlinePulseTimer then
      offlinePulseTimer:Stop()
      offlinePulseTimer = nil
    end
    pulseOn = false
    ctrl.String = "Online"
    ctrl.Color = "#00C800"  -- green

  elseif state == "offline" then
    ctrl.String = "Offline"

    if not offlinePulseTimer then
      offlinePulseTimer = Timer.New()
      offlinePulseTimer.EventHandler = function()
        pulseOn = not pulseOn
        ctrl.Color = pulseOn and "#C80000" or "#800000"  -- bright red / dim red
      end
      offlinePulseTimer:Start(0.5)
    end
  end
end

--------------------------------------------------------------------------------
-- Group States
--------------------------------------------------------------------------------
function SetGroupLabel(groupId, name)
  local ctrl = Controls["group_label_" .. groupId]
  if not ctrl then return end

  -- Set label name only (ID shown in badge)
  ctrl.String = name

  -- Set group color
  local color = GROUP_COLORS["Group: " .. groupId]
  if color then
    local r, g, b = table.unpack(color)
    local hex = string.format("#%02X%02X%02X", r, g, b)
    ctrl.Color = hex
  else
    ctrl.Color = "#00000000"
  end

  -- Update group ID badge
  local badgeCtrl = Controls["group_id_badge_" .. groupId]
  if badgeCtrl then
    local groupMeta = state.groupMeta and state.groupMeta[groupId]
    badgeCtrl.String = groupMeta and tostring(groupMeta.id) or ""
  end
end

-- Utility: Redraw group page if visible
function updateGroupUI(groupId)
  if currentPage == "Groups" then
    RedrawControls() -- forces full re-layout if we're on the Groups page
  end
end

