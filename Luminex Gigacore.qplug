local pageBuilders = {
  ["Port settings"] = function(layout, gfx, props)
    buildPortSettingsPage(layout, gfx, props)
  end,

  ["Configuration"] = buildConfigurationPage,
  ["Groups"] = buildGroupTrunkSettingsPage,
--  ["Testing"] = buildTestingPage,

  -- fallback for all model tabs
  __index = function(_, key)
    return function(layout, gfx, props)
      local model = props["Model"] and props["Model"].Value or "GigaCore 30i"
      buildControlsPage(layout, gfx, getPortCount(model))
    end
  end
}
setmetatable(pageBuilders, pageBuilders)
--------------------------------------------------------------------------------
-- GetControlLayout
--------------------------------------------------------------------------------
function GetControlLayout(props)
  -- Update dark mode on every redraw (based on property value)
  local darkProp = props["Dark Mode"]
  local darkModeValue = (type(darkProp) == "table") and darkProp.Value or darkProp
  state.darkMode = (darkModeValue == "No")

  local pages = GetPages(props)
  local idx = props["page_index"] and props["page_index"].Value or 1
  local pageObj = pages[idx]
  local pageName = pageObj and pageObj.name or "GigaCore 30i"
  
  local layout = {}
  local gfx = {}
  
  local builder = pageBuilders[pageName]
  if builder then
    builder(layout, gfx, props)
  end

  return layout, gfx
end
--------------------------------------------------------------------------------
-- CONTROL EVENT HANDLERS
--------------------------------------------------------------------------------
if Controls then

  -- Apply test dropdown choices
  if Controls["test_dropdown"] then
    Controls["test_dropdown"].Choices = SPEED_CHOICES
  end

  local pc = state.portCount or 30

  -- Ensure all dropdowns have an EventHandler attached before WebSocket updates use .String
  for p = 1, pc do
    local ctrl = Controls["port_speed_dropdown_" .. p]
    if ctrl then
      ctrl.Choices = SPEED_CHOICES
      if not ctrl.EventHandler then
        ctrl.EventHandler = function() end  -- Dummy handler for Q-SYS
      end
    end
  end

  Controls["ip_addr"].EventHandler = function(txt)
    state.baseIP = txt.String
  end

  Controls["connect"].EventHandler = function(btn)
    if btn.Boolean then
      updateAuthStatus("")  -- Clear auth status on new attempt
      state.baseIP = Controls["ip_addr"].String
      openWS(state.baseIP)
      btn.Boolean = false
    end
  end

  Controls["identify"].EventHandler = function(btn)
    if btn.Boolean and state.baseIP ~= "" then
      local url = string.format("http://%s/api/identify", state.baseIP)
      local body = '{"duration": 9}'

      HttpClient.Upload{
        Url     = url,
        Method  = "PUT",
        Data    = body,
        Headers = MergeTables(
          { ["Content-Type"] = "application/json" },
          getAuthHeaders()
        ),
        EventHandler = function(rBody, status, err) end
      }

      btn.Boolean = false
    end
  end


                                                                                                                                                  -- Enabled
  for p = 1, pc do
    local ctrl = Controls["port_enable_toggle_"..p]
    if ctrl then
      ctrl.EventHandler = function()
        local newState = ctrl.Boolean
        local url = string.format("http://%s/api/ports/port/%d/enabled", state.baseIP, p)
  
        HttpClient.Upload{
          Url     = url,
          Method  = "PUT",
          Data    = newState and "true" or "false",
          Headers = MergeTables(
            { ["Content-Type"] = "application/json" },
            getAuthHeaders()
          ),
          EventHandler = function(body, code, err)
            log("Port "..p.." enable set to "..tostring(newState).." | HTTP "..tostring(code))
          end
        }
      end
    end
  end

  -- Legend edit bindings
  for p = 1, pc do
    local legendCtrl = Controls["port_legend_edit_"..p]
    if legendCtrl then
      legendCtrl.EventHandler = function(ctrl)
        local newVal = ctrl.String
        local url = string.format("http://%s/api/ports/port/%d/legend", state.baseIP, p)
        local body = qsc_json.encode(newVal)
        HttpClient.Upload{
          Url     = url,
          Method  = "PUT",
          Data    = body,
          Headers = MergeTables(
            { ["Content-Type"] = "application/json" },
            getAuthHeaders()
          ),
          EventHandler = function(rBody, status, err) end
        }
      end
    end
  end
                                                                                                                                             -- Rlinkx
  -- RLinkX toggle bindings
  for p = 1, pc do
    local toggleCtrl = Controls["port_rlinkx_toggle_"..p]
    if toggleCtrl then
      toggleCtrl.EventHandler = function(ctrl)
        local enabled = ctrl.Boolean
        local url = string.format("http://%s/api/ports/port/%d/rlinkx", state.baseIP, p)
        local body = qsc_json.encode({ enabled = enabled })
        HttpClient.Upload{
          Url     = url,
          Method  = "PUT",
          Data    = body,
          Headers = MergeTables(
            { ["Content-Type"] = "application/json" },
            getAuthHeaders()
          ),
          EventHandler = function(rBody, status, err)
            log("RLinkX PUT port " .. p .. " => " .. tostring(enabled))
          end
        }
      end
    end
  end

-- PoE Bounce button bindings                                                                                                                                    -- bounce
  for p = 1, pc do
    local bounceCtrl = Controls["port_bounce_btn_"..p]
    if bounceCtrl then
      local port = p  -- fix scope
      bounceCtrl.EventHandler = function()
        local delay = tonumber(Controls["poe_bounce_delay"].String or "") or 3
        local url   = string.format("http://%s/api/poe/ports/%d/enabled", state.baseIP, port)
  
        -- Disable PoE
        HttpClient.Upload{
          Url     = url,
          Method  = "PUT",
          Data    = "false",
          Headers = MergeTables(
            { ["Content-Type"] = "application/json" },
            getAuthHeaders()
          ),
          EventHandler = function(rBody, status, err)
            log("PoE DISABLE port " .. port .. ": HTTP " .. tostring(status or "nil"))
  
            -- Re-enable after delay
            Timer.CallAfter(delay, function()
              log("Timer expired — re-enabling PoE on port " .. port .. " after " .. delay .. "s delay")
              HttpClient.Upload{
                Url     = url,
                Method  = "PUT",
                Data    = '"true"',                                      -- test pour poe Bounce = "true",
                Headers = MergeTables(
                  { ["Content-Type"] = "application/json" },
                  getAuthHeaders()
                ),
                EventHandler = function(rBody, status, err)
                  log("PoE ENABLE port " .. port .. ": HTTP " .. tostring(status or "nil"))
                end
              }
            end)
          end
        }
      end
    end
  end

  -- Speed dropdown event handlers
  for p = 1, pc do
    local dropdown = Controls["port_speed_dropdown_"..p]
    if dropdown then
      dropdown.EventHandler = function(ctrl)
        local val = ctrl.String

        -- Disable ports
        if val == "Disabled" then
          HttpClient.Upload{
            Url     = string.format("http://%s/api/ports/port/%d/enabled", state.baseIP, p),
            Method  = "PUT",
            Data    = '"false"',
            Headers = MergeTables(
              { ["Content-Type"] = "application/json" },
              getAuthHeaders()
            ),
            EventHandler = function(_, status, err)
              log("Disabled port " .. p .. " => status: " .. tostring(status) .. ", err: " .. tostring(err))
            end
          }
          return
        end

        -- Enable ports
        HttpClient.Upload{
          Url     = string.format("http://%s/api/ports/port/%d/enabled", state.baseIP, p),
          Method  = "PUT",
          Data    = '"true"',
          Headers = MergeTables(
            { ["Content-Type"] = "application/json" },
            getAuthHeaders()
          ),
          EventHandler = function(_, status, err)
            log("Enabled port " .. p .. " => status: " .. tostring(status) .. ", err: " .. tostring(err))
          end
        }

        -- Send speed config
        local url = string.format("http://%s/api/ports/port/%d/link_speed", state.baseIP, p)
        local payload = {}

        if val == "Auto" then
          payload = { mode = "auto", speed = { "all" } }
        elseif SPEED_API_MAP[val] then
          payload = { mode = "fixed", speed = { SPEED_API_MAP[val] } }
        end

        HttpClient.Upload{
          Url     = url,
          Method  = "PUT",
          Data    = qsc_json.encode(payload),
          Headers = MergeTables(
            { ["Content-Type"] = "application/json" },
            getAuthHeaders()
          ),
          EventHandler = function(_, status, err)
            log("Set link_speed on port " .. p .. " => status: " .. tostring(status) .. ", err: " .. tostring(err))
          end
        }
      end
    end
  end
end
log("Enjoy")
