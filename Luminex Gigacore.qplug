local pageBuilders = {
  ["Port settings"] = function(layout, gfx, props)
    buildPortSettingsPage(layout, gfx, props)
  end,

  ["Configuration"] = buildConfigurationPage,
  ["Groups"] = buildGroupTrunkSettingsPage,
--  ["Testing"] = buildTestingPage,

  -- fallback for all model tabs
  __index = function(_, key)
    return function(layout, gfx, props)
      local model = props["Model"] and props["Model"].Value or "GigaCore 30i"
      buildControlsPage(layout, gfx, getPortCount(model))
    end
  end
}
setmetatable(pageBuilders, pageBuilders)

--------------------------------------------------------------------------------
-- GetControlLayout
--------------------------------------------------------------------------------
function GetControlLayout(props)
  -- Update dark mode on every redraw (based on property value)
  local darkProp = props["Dark Mode"]
  local darkModeValue = (type(darkProp) == "table") and darkProp.Value or darkProp
  state.darkMode = (darkModeValue == "No")

  local pages = GetPages(props)
  local idx = props["page_index"] and props["page_index"].Value or 1
  local pageObj = pages[idx]
  local pageName = pageObj and pageObj.name or "GigaCore 30i"

  local layout = {}
  local gfx = {}

  local builder = pageBuilders[pageName]
  if builder then
    builder(layout, gfx, props)
  end

  return layout, gfx
end

--------------------------------------------------------------------------------
-- CONTROL EVENT HANDLERS
--------------------------------------------------------------------------------
if Controls then

  local pc = state.portCount or 30

  ---------------------------------------------------------------------------
  -- Speed dropdown
  ---------------------------------------------------------------------------
  for p = 1, pc do
    local ctrl = Controls["port_speed_dropdown_" .. p]
    if ctrl then
      ctrl.Choices = {
        "Auto",
        "Disabled",
        "10gbps fdx",
        "2.5gbps fdx",
        "1gbps fdx",
        "100mbps fdx",
        "100mbps hdx",
        "10mbps fdx",
        "10mbps hdx"
      }
    end
  end

  ---------------------------------------------------------------------------
  -- IP / connect / identify
  ---------------------------------------------------------------------------
  if Controls["ip_addr"] then
    Controls["ip_addr"].EventHandler = function(txt)
      state.baseIP = txt.String
    end
  end

  if Controls["connect"] then
    Controls["connect"].EventHandler = function(btn)
      if btn.Boolean then
        updateAuthStatus("") -- Clear auth status on new attempt
        state.baseIP = Controls["ip_addr"].String
        openWS(state.baseIP)
        btn.Boolean = false
      end
    end
  end

  if Controls["identify"] then
    Controls["identify"].EventHandler = function(btn)
      if btn.Boolean and state.baseIP ~= "" then
        local url  = string.format("http://%s/api/identify", state.baseIP)
        local body = '{"duration": 9}'

        HttpClient.Upload{
          Url     = url,
          Method  = "PUT",
          Data    = body,
          Headers = MergeTables(
            { ["Content-Type"] = "application/json" },
            getAuthHeaders()
          ),
          EventHandler = function(rBody, status, err) end
        }

        btn.Boolean = false
      end
    end
  end

  ---------------------------------------------------------------------------
  -- Port enabled toggle
  ---------------------------------------------------------------------------
  for p = 1, pc do
    local ctrl = Controls["port_enable_toggle_" .. p]
    if ctrl then
      ctrl.EventHandler = function()
        local newState = ctrl.Boolean
        local url = string.format("http://%s/api/ports/port/%d/enabled", state.baseIP, p)

        HttpClient.Upload{
          Url     = url,
          Method  = "PUT",
          Data    = newState and "true" or "false",
          Headers = MergeTables(
            { ["Content-Type"] = "application/json" },
            getAuthHeaders()
          ),
          EventHandler = function(body, code, err)
            log("Port " .. p .. " enable set to " .. tostring(newState) .. " | HTTP " .. tostring(code))
          end
        }
      end
    end
  end

  ---------------------------------------------------------------------------
  -- PoE Enabled toggle
  ---------------------------------------------------------------------------
  for p = 1, pc do
    local ctrl = Controls["port_poe_toggle_" .. p]
    if ctrl then
      ctrl.EventHandler = function()
        local newState = ctrl.Boolean
        local url = string.format("http://%s/api/poe/ports/%d/enabled", state.baseIP, p)

        HttpClient.Upload{
          Url     = url,
          Method  = "PUT",
          Data    = newState and "true" or "false",
          Headers = MergeTables(
            { ["Content-Type"] = "application/json" },
            getAuthHeaders()
          ),
          EventHandler = function(body, code, err)
            log("PoE " .. p .. " enabled set to " .. tostring(newState) .. " | HTTP " .. tostring(code))
          end
        }
      end
    end
  end

  ---------------------------------------------------------------------------
  -- Legend edit bindings
  ---------------------------------------------------------------------------
  for p = 1, pc do
    local legendCtrl = Controls["port_legend_edit_" .. p]
    if legendCtrl then
      legendCtrl.EventHandler = function(ctrl)
        local newVal = ctrl.String
        local url  = string.format("http://%s/api/ports/port/%d/legend", state.baseIP, p)
        local body = qsc_json.encode(newVal)

        HttpClient.Upload{
          Url     = url,
          Method  = "PUT",
          Data    = body,
          Headers = MergeTables(
            { ["Content-Type"] = "application/json" },
            getAuthHeaders()
          ),
          EventHandler = function(rBody, status, err) end
        }
      end
    end
  end

  ---------------------------------------------------------------------------
  -- RLinkX toggle bindings
  ---------------------------------------------------------------------------
  for p = 1, pc do
    local toggleCtrl = Controls["port_rlinkx_toggle_" .. p]
    if toggleCtrl then
      toggleCtrl.EventHandler = function(ctrl)
        local enabled = ctrl.Boolean
        local url  = string.format("http://%s/api/ports/port/%d/rlinkx", state.baseIP, p)
        local body = qsc_json.encode({ enabled = enabled })

        HttpClient.Upload{
          Url     = url,
          Method  = "PUT",
          Data    = body,
          Headers = MergeTables(
            { ["Content-Type"] = "application/json" },
            getAuthHeaders()
          ),
          EventHandler = function(rBody, status, err)
            log("RLinkX PUT port " .. p .. " => " .. tostring(enabled))
          end
        }
      end
    end
  end

---------------------------------------------------------------------------
-- Speed dropdown event handlers
-- IMPORTANT:
--  - No optimistic speed update
--  - UI is marked pending until WS confirmation
---------------------------------------------------------------------------
---------------------------------------------------------------------------
-- Speed dropdown event handlers
-- Step 3: rollback on REST error
---------------------------------------------------------------------------
  for p = 1, pc do
    local dropdown = Controls["port_speed_dropdown_" .. p]
    if dropdown then
      dropdown.EventHandler = function(ctrl)
        local val  = ctrl.String
        local port = p
        local pstate = getPortState(port)

---------------------------------------------------------------------
-- Disabled => disable port and exit
---------------------------------------------------------------------
        if val == "Disabled" then
          HttpClient.Upload{
            Url     = string.format("http://%s/api/ports/port/%d/enabled", state.baseIP, port),
            Method  = "PUT",
            Data    = "false",
            Headers = MergeTables(
              { ["Content-Type"] = "application/json" },
              getAuthHeaders()
            ),
            EventHandler = function(_, status, err)
              log("Disabled port " .. port ..
                  " => status: " .. tostring(status) ..
                  ", err: " .. tostring(err))
            end
          }
          return
        end

---------------------------------------------------------------------
-- Ensure port enabled
---------------------------------------------------------------------
        HttpClient.Upload{
          Url     = string.format("http://%s/api/ports/port/%d/enabled", state.baseIP, port),
          Method  = "PUT",
          Data    = "true",
          Headers = MergeTables(
            { ["Content-Type"] = "application/json" },
            getAuthHeaders()
          ),
          EventHandler = function(_, status, err)
            log("Enabled port " .. port ..
                " => status: " .. tostring(status) ..
                ", err: " .. tostring(err))
          end
        }

---------------------------------------------------------------------
-- Mark speed as pending
---------------------------------------------------------------------
        pstate.speedPending = true
        renderPortUI(port)

---------------------------------------------------------------------
-- Build link_speed payload
---------------------------------------------------------------------
        local payload
        if val == "Auto" then
          payload = { mode = "auto", speed = { "all" } }

        elseif val == "1gbps fdx" then
          payload = { mode = "auto", speed = { "1gbps fdx" } }

        else
          payload = { mode = "fixed", speed = { val } }
        end

---------------------------------------------------------------------
-- Send link_speed PUT with rollback on error
---------------------------------------------------------------------
        HttpClient.Upload{
          Url     = string.format(
            "http://%s/api/ports/port/%d/link_speed",
            state.baseIP,
            port
          ),
          Method  = "PUT",
          Data    = qsc_json.encode(payload),
          Headers = MergeTables(
            { ["Content-Type"] = "application/json" },
            getAuthHeaders()
          ),
          EventHandler = function(_, status, err)
            log("Set link_speed on port " .. port ..
                " => " .. qsc_json.encode(payload) ..
                " | status: " .. tostring(status) ..
                ", err: " .. tostring(err))

            -- REST rejected => rollback
            if status ~= 200 then
              log("Link speed rejected on port " .. port)

              pstate.speedPending = false

              if pstate.lastValidSpeed then
                pstate.speed = pstate.lastValidSpeed
              end

              renderPortUI(port)
            end
            -- Success case:
            -- WS will confirm and call SetPortSpeed()
          end
        }
      end
    end
  end
end
log("Enjoy")
