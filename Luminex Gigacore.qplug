--------------------------------------------------------------------------------
-- Light/Dark Theme
--------------------------------------------------------------------------------
local function getThemeColors()
  return {
    groupboxFill     = state.darkMode and {12, 21, 42}         or {240, 245, 255, 255},
    textColor        = state.darkMode and {180, 255, 255}      or {75, 0, 0, 255},
    textboxColor     = state.darkMode and {0, 0, 0}            or {0, 0, 0},
    textboxBg        = state.darkMode and {40, 40, 60, 180}    or {215, 200, 180, 255},
    buttonColor      = state.darkMode and {0, 150, 255}        or {255, 105, 0, 255},
    buttonAltColor   = state.darkMode and {0, 150, 255}        or {255, 105, 0, 255},
    buttonOffColor   = state.darkMode and {60, 60, 60}         or {200, 200, 200, 255},
    indicatorFill    = state.darkMode and {20, 24, 40, 230}    or {240, 245, 255, 255},
    strokeColor      = state.darkMode and {60, 60, 60}         or {120, 120, 120, 255},
    rectangleFill    = state.darkMode and {30, 40, 60, 220}    or {240, 245, 255, 255},
    labelGray        = state.darkMode and {200, 200, 200}      or {230, 230, 230, 255}
  }
end
--------------------------------------------------------------------------------
-- Helper function to map model name -> number of ports
--------------------------------------------------------------------------------
local function getPortCount(model)
  return GigaCoreModels[model] or 30
end
--------------------------------------------------------------------------------
-- Compute page size for the "Controls" page
--------------------------------------------------------------------------------
local function getControlsPageSize(portCount)     
  local columns         = math.ceil(portCount / 2)
  local btnW, btnH      = 66, 38
  local colSpacing      = 8
  local leftRightMargin = 40
  local totalPortsW = columns * btnW + (columns - 1)*colSpacing
  local totalW = totalPortsW + leftRightMargin*2
  local totalH = 300          -- page height

  return totalW, totalH
end
--------------------------------------------------------------------------------
-- Utility / Logging
--------------------------------------------------------------------------------
local function log(m)
  print(tostring(m))
end

local Json = Json
--------------------------------------------------------------------------------
-- Basic Auth
--------------------------------------------------------------------------------
function MergeTables(a, b)
  local result = {}
  for k, v in pairs(a) do result[k] = v end
  for k, v in pairs(b) do result[k] = v end
  return result
end

local function getAuthHeaders()
  local user = Controls["auth_username"] and Controls["auth_username"].String or ""
  local pass = Controls["auth_password"] and Controls["auth_password"].String or ""
  if user == "" or pass == "" then return {} end
  local token = Crypto.Base64Encode(user .. ":" .. pass)
  return { ["Authorization"] = "Basic " .. token }
end
--------------------------------------------------------------------------------
-- WebSocket Setup
--------------------------------------------------------------------------------
local function subscribeAllPorts()
  if not state.ws then
    return
  end

  for i = 1, state.portCount do       -- state.portCount loop only as many ports as the chosen model has
    local linkMsg= string.format('{"subscription":{"path":"/ports/port/%d/link_state","action":"add","method":"changes"}}', i)
    state.ws:Write(linkMsg)
    local memberMsg= string.format('{"subscription":{"path":"/ports/port/%d/member_of","action":"add","method":"changes"}}', i)
    state.ws:Write(memberMsg)
	local indMsg= string.format('{"subscription":{"path":"/poe/ports/%d/indication","action":"add","method":"changes"}}', i)
    state.ws:Write(indMsg)	
	local rlinkxMsg= string.format('{"subscription":{"path":"/ports/port/%d/rlinkx","action":"add","method":"changes"}}', i)                                                                               --   1-RlinkX
    state.ws:Write(rlinkxMsg)
	local legendMsg= string.format('{"subscription":{"path":"/ports/port/%d/legend","action":"add","method":"changes"}}', i)
    state.ws:Write(legendMsg)
    local enabledMsg = string.format('{"subscription":{"path":"/ports/port/%d/enabled","action":"add","method":"changes"}}', i)                                                                             --  1-Enabled
    state.ws:Write(enabledMsg)	
    local speedMsg = string.format('{"subscription":{"path":"/ports/port/%d/link_speed","action":"add","method":"changes"}}', i)
    state.ws:Write(speedMsg)	
  end
  local devMsg = '{"subscription":{"path":"/device/name","action":"add","method":"changes"}}'
  state.ws:Write(devMsg)
  local descMsg = '{"subscription":{"path":"/device/description","action":"add","method":"changes"}}'
  state.ws:Write(descMsg)  
  local actualIPMsg = '{"subscription":{"path":"/device/actual_ip/ip_address","action":"add","method":"changes"}}'
  state.ws:Write(actualIPMsg)  
  local prefixLengthMsg = '{"subscription":{"path":"/device/actual_ip/prefix_length","action":"add","method":"changes"}}'
  state.ws:Write(prefixLengthMsg)   
  local IPmodeMsg = '{"subscription":{"path":"/ip_settings/mode","action":"add","method":"changes"}}'
  state.ws:Write(IPmodeMsg)
  local macMsg = '{"subscription":{"path":"/device/mac_address","action":"add","method":"changes"}}'
  state.ws:Write(macMsg)
  local firmMsg = '{"subscription":{"path":"/device/firmware/active","action":"add","method":"changes"}}'
  state.ws:Write(firmMsg)  
end

-- For group page
local MAX_GROUPS = 40

function subscribeAllGroups()
  if not state.ws then return end

  for i = 1, MAX_GROUPS do
    -- Subscribe to name
    local nameMsg = string.format('{"subscription":{"path":"/groups/group/%d/name","action":"add","method":"changes"}}', i)
    state.ws:Write(nameMsg)

    -- Subscribe to group_id
    local idMsg = string.format('{"subscription":{"path":"/groups/group/%d/group_id","action":"add","method":"changes"}}', i)
    state.ws:Write(idMsg)
  end
end



local function openWS(ip)
  state.baseIP = ip

  if state.ws then
    state.ws:Close()
    state.ws = nil
  end

  state.ws = WebSocket.New()

  state.ws.Connected = function()
    log("WebSocket Connected => subscribeAllPorts()")
  
    updateAuthStatus("Authenticated", "#00A000")  -- green status
  
    subscribeAllPorts()
	subscribeAllGroups()
    SetDeviceStatus("online")
  end

  state.ws.Data = function(_, data)
    log("Data: " .. tostring(data))
    if data:find('"api_notification"') then
      parseNotification(data)
    end
  end

  state.ws.Error = function(_, err)
    log("WebSocket Error: " .. (err or "none"))
	if err and err:find("unauthorized") then
	  updateAuthStatus("Auth failed", "#C80000")
	end  
    SetDeviceStatus("offline")
    Timer.CallAfter(function() openWS(state.baseIP) end, 5)
  end

  state.ws.Closed = function()
    log("WebSocket Closed")
    SetDeviceStatus("offline")
    Timer.CallAfter(function() openWS(state.baseIP) end, 5)
  end

  -- Get credentials from UI
  local user = Controls["auth_username"] and Controls["auth_username"].String or ""
  local pass = Controls["auth_password"] and Controls["auth_password"].String or ""
  local headers = {}

  if user ~= "" and pass ~= "" then
    local token = Crypto.Base64Encode(user .. ":" .. pass)
    headers["Authorization"] = "Basic " .. token
  end

  log("Connecting => ws://" .. ip .. "/api/ws on port 80")
  state.ws:Connect("ws", ip, "api/ws", 80, nil, headers)
end
--------------------------------------------------------------------------------
-- IP Info 
--------------------------------------------------------------------------------
local function updateIPinfo()                             -- To format to: "192.168.10.25/16 (static)" 
  local ip    = (state.currentIP    ~= "" and state.currentIP)    or "???"
  local pref  = (state.prefixLength ~= "" and state.prefixLength) or "??"
  local mode  = (state.ipMode       ~= "" and state.ipMode)       or "???"
  local combined = string.format("%s/%s (%s)", ip, pref, mode)
  if Controls["ip_info"] then                               -- Now set the single text control
    Controls["ip_info"].String = combined
  end
end
--------------------------------------------------------------------------------
-- Device name and device description
--------------------------------------------------------------------------------
local function formatDeviceName(rawName)                      -- Format Device Name/Description
  if #rawName > 32 then                                       -- more than 32 characters, insert a newline
    local part1 = string.sub(rawName, 1, 32)
    local part2 = string.sub(rawName, 33)
    return part1 .. "\n" .. part2
  else
    return rawName
  end
end
local function formatDeviceDesc(rawDesc)
  if #rawDesc > 32 then
    local part1 = string.sub(rawDesc, 1, 32)
    local part2 = string.sub(rawDesc, 33)
    return part1 .. "\n" .. part2
  else
    return rawDesc
  end
end
--------------------------------------------------------------------------------
-- mac address and firmware
--------------------------------------------------------------------------------
local function updateMac_Firmware()                           -- To format to: "d0:69:9e:00:00:00 - 1.6.0" 
  local mac = state.macAddress ~= "" and state.macAddress or "??:??:??:??:??:??"
  local firm = state.firmwareVersion ~= "" and state.firmwareVersion or "?.?.?"
  local combined = string.format("%s  –  %s", mac, firm)
  if Controls["mac_firmware"] then
    Controls["mac_firmware"].String = combined
  end
end
--------------------------------------------------------------------------------
-- updateAuthStatus
--------------------------------------------------------------------------------
function updateAuthStatus(text, color)
  local ctrl = Controls["auth_status"]
  if not ctrl then return end

  ctrl.String = text
  ctrl.Color = (text ~= "") and (color or "#800000") or "#00000000"
end

--------------------------------------------------------------------------------
-- PoE bounce ⚡ logo show when sourcing
--------------------------------------------------------------------------------
function SetPortIndication(port, value)
  portPoEIndication[port] = value

  local ctrl = Controls["port_bounce_btn_" .. port]
  if ctrl then
    if value == "sourcing" then
      ctrl.Legend = "⚡"
    else
      ctrl.Legend = ""
    end
  end
end
--------------------------------------------------------------------------------
-- Parse Notifications
--------------------------------------------------------------------------------
function parseNotification(raw)
  log("parseNotification => " .. raw)
  local path= raw:match('"path"%s*:%s*"([^"]+)"')
  if not path then return end

  if path:find("/device/name") then
    local newVal = raw:match('"new_value"%s*:%s*"([^"]+)"')
    if newVal then
      local formatted = formatDeviceName(newVal)
      Controls["device_name"].String = formatted
    end
    return
  end

  if path:find("/device/description") then
    local newVal = raw:match('"new_value"%s*:%s*"([^"]+)"')
    if newVal then
      local formattedDesc = formatDeviceDesc(newVal)
      Controls["device_description"].String = formattedDesc
    end
    return
  end

  if path:find("/device/mac_address") then
    local newVal = raw:match('"new_value"%s*:%s*"([^"]+)"')
    if newVal then
      state.macAddress = newVal
      updateMac_Firmware()
    end
    return
  end

  if path:find("/device/firmware/active") then
    local newVal = raw:match('"new_value"%s*:%s*"([^"]+)"')
    if newVal then
      state.firmwareVersion = newVal
      updateMac_Firmware()
    end
    return
  end

  if path:find("/device/actual_ip/ip_address") then
    local newVal = raw:match('"new_value"%s*:%s*"([^"]+)"')
    if newVal then
      state.currentIP = newVal
      updateIPinfo()
    end
    return
  end

  if path:find("/device/actual_ip/prefix_length") then
    local newVal = raw:match('"new_value"%s*:%s*(%d+)')
    if newVal then
      state.prefixLength = newVal
      updateIPinfo()
    end
    return
  end

  if path:find("/ip_settings/mode") then
    local newVal = raw:match('"new_value"%s*:%s*"([^"]+)"')
    if newVal then
      state.ipMode = newVal
      updateIPinfo()
    end
    return
  end

  -- Handle group name updates                                                                                              ----------------------------
  if path:find("/groups/group/") and path:find("/name") then
    local groupId = path:match("/groups/group/(%d+)/name")
    local newName = raw:match('"new_value"%s*:%s*"([^"]+)"')
    if groupId and newName then
      local gid = tonumber(groupId)
      state.groupNames[gid] = newName

      local ctrl = Controls["group_label_"..gid]
      if ctrl then
        SetGroupLabel(gid, newName)
      end
    end
    return
  end

-- Handle group_id updates
  if path:match("^/groups/group/%d+/group_id$") then
    local groupId = tonumber(path:match("/groups/group/(%d+)/group_id"))
    local newVal = tonumber(raw:match('"new_value"%s*:%s*(%d+)'))
  
    if groupId and newVal then
      state.groupMeta = state.groupMeta or {}
      state.groupMeta[groupId] = state.groupMeta[groupId] or {}
      state.groupMeta[groupId].id = newVal
  
      updateGroupUI(groupId)  -- 🔁 force layout refresh
    end
    return
  end




  -- Port Enabled state
  if path:find("/enabled") then
    local boolStr = raw:match('"new_value"%s*:%s*(%a+)')
    if boolStr then
      local port = tonumber(path:match("/port/(%d+)/enabled"))
      if port and Controls["port_enable_toggle_"..port] then
        Controls["port_enable_toggle_"..port].Boolean = (boolStr == "true")
      end
    end
    return
  end

  -- /legend
  local portStr = path:match("/ports/port/(%d+)/legend")
  if portStr then
    local portNum = tonumber(portStr)
    local newVal  = raw:match('"new_value"%s*:%s*"([^"]+)"')
    if newVal then
      local displayCtrl = Controls["port_legend_display_"..portNum]
      if displayCtrl then
        local splitVal = newVal
        if #newVal > 8 then
          splitVal = newVal:sub(1,8) .. " \n" .. newVal:sub(9)
        end
        displayCtrl.String = splitVal
      end

      local editCtrl = Controls["port_legend_edit_"..portNum]
      if editCtrl then
        editCtrl.String = newVal
      end
    end
    return
  end

  -- link_state
  local pStr = path:match("/port/(%d+)/") or path:match("/poe/ports/(%d+)/")
  if not pStr then return end
  local port = tonumber(pStr)

  if path:find("/link_state") then
    local newVal = raw:match('"new_value"%s*:%s*"([^"]+)"')
    if newVal then
      local isOn = false
      if newVal ~= "down" and newVal ~= "unknown" then
        isOn = true
      end
      SetPortLink(port, isOn)
    end
    return
  end

  -- member_of
  if path:find("/member_of") then
    local obj = raw:match('"new_value"%s*:%s*{(.-)}')
    if obj then
      local tVal = obj:match('"type"%s*:%s*"([^"]+)"')
      local idVal = obj:match('"id"%s*:%s*(%d+)')
      if tVal and idVal then
        if tVal == "trunk" then
          SetPortMemberOf(port, "Trunk: "..idVal)
        elseif tVal == "group" then
          SetPortMemberOf(port, "Group: "..idVal)
        end
      end
    else
      local newValString = raw:match('"new_value"%s*:%s*"([^"]+)"')
      if newValString then
        local gId = newValString:match("^group(%d+)$")
        if gId then
          SetPortMemberOf(port, "Group: "..gId)
        elseif newValString == "trunk" then
          SetPortMemberOf(port, "Trunk")
        else
          SetPortMemberOf(port, newValString)
        end
      end
    end
  end

  -- Indication (PoE)
  if path:find("/indication") then
    local newVal = raw:match('"new_value"%s*:%s*"([^"]+)"')
    if newVal then
      SetPortIndication(port, newVal)
    end
    return
  end

  -- rlinkx
  if path:find("/rlinkx") then
    local obj = raw:match('"new_value"%s*:%s*{(.-)}')
    if obj then
      local boolString = obj:match('"enabled"%s*:%s*(%a+)')
      if boolString then
        local stateVal = (boolString == "true") and "enabled" or "disabled"

        local label = Controls["rlinkx"..port]
        if label then
          label.String = (stateVal == "enabled") and "On" or "Off"
        end

        SetPortRlinkx(port, stateVal)

        local toggle = Controls["port_rlinkx_toggle_"..port]
        if toggle then
          toggle.Boolean = (stateVal == "enabled")
        end
      end
    end
    return
  end

  if path:find("/enabled") then
    local portStr = path:match("/ports/port/(%d+)/enabled")
    if portStr then
      local port = tonumber(portStr)
      local ctrl = Controls["port_speed_dropdown_"..port]
      if not ctrl then return end

      local val = raw:match('"new_value"%s*:%s*(%a+)')
      if val == "false" then
        ctrl.String = "Disabled"
        state["port_enabled_"..port] = false
      else
        state["port_enabled_"..port] = true
      end
    end
    return
  end

  if path:find("/link_speed") then
    local portStr = path:match("/ports/port/(%d+)/link_speed")
    if portStr then
      local port = tonumber(portStr)
      local ctrl = Controls["port_speed_dropdown_"..port]
      if not ctrl then return end

      if state["port_enabled_"..port] == false then
        return
      end

      local jsonMode = raw:match('"mode"%s*:%s*"([^"]+)"')
      local jsonSpeed = raw:match('"speed"%s*:%s*%[%"([^"]+)"%]')

      if jsonMode == "auto" then
        ctrl.String = "Auto"
      elseif jsonMode == "fixed" and jsonSpeed then
        local reverseMap = {
          ["1gbps fdx"] = "1 Gbps",
          ["100mbps fdx"] = "100 Mbps (Full-duplex)",
          ["100mbps hdx"] = "100 Mbps (Half-duplex)",
          ["10mbps fdx"] = "10 Mbps (Full-duplex)",
          ["10mbps hdx"] = "10 Mbps (Half-duplex)"
        }
        ctrl.String = reverseMap[jsonSpeed] or ""
      end
    end
    return
  end
end

--------------------------------------------------------------------------------
-- Set Port States
--------------------------------------------------------------------------------
function SetPortLink(port, isOn)
  local ctrl=Controls["port"..port]
  if ctrl then
    ctrl.Boolean=isOn
  end
end

function SetPortMemberOf(port, textVal)

  state.portGroupAssignments = state.portGroupAssignments or {}
  state.portGroupAssignments[port] = textVal

  local ctrl = Controls["port_group_color_"..port]
  if ctrl then
    local color = GROUP_COLORS[textVal]
    if not color then
      ctrl.Color = "#00000000"
      ctrl.String = textVal
      return
    end
  
    local r, g, b = table.unpack(color)
    local hex = string.format("#%02X%02X%02X", r, g, b)
  
    ctrl.String = textVal
    ctrl.Color = hex
  end
end

function SetPortIndication(port, textVal)
  local label = Controls["indication"..port]
  if label then
    label.String = textVal
  end

  -- Apply color to poe rectangle
  local box = Controls["poe_color_"..port]
  if box then
    local colorMap = {
      sourcing = "#FF8000",   -- orange
      enabled  = "#FFD700",   -- yellow
      disabled = "#444444",   -- dark gray
    }

    local color = colorMap[textVal:lower()]
    if color then
      box.Color = color
      box.String = ""
    else
      box.Color = "#00000000"
      box.String = ""
    end
  end

  -- Update bounce button legend on Port Settings page                                                                                                               -- BOUNCE
  local bounce = Controls["port_bounce_btn_" .. port]
  if bounce then
    bounce.Legend = (textVal:lower() == "sourcing") and "⚡" or ""
  end
end


function SetPortRlinkx(port, stateString)
  local ctrl = Controls["rlinkx_bar_"..port]
  if ctrl then
    local colorMap = {
      enabled = "#00B2FF",  -- blue
      disabled = "#999999", -- light gray
    }
    local color = colorMap[stateString:lower()] or "#00000000"
    ctrl.Color = color
    ctrl.String = ""
  end
end

function SetDeviceStatus(state)
  local ctrl = Controls["device_status"]
  if not ctrl then return end

  if state == "online" then
    if offlinePulseTimer then
      offlinePulseTimer:Stop()
      offlinePulseTimer = nil
    end
    pulseOn = false
    ctrl.String = "Online"
    ctrl.Color = "#00C800"  -- green

  elseif state == "offline" then
    ctrl.String = "Offline"

    if not offlinePulseTimer then
      offlinePulseTimer = Timer.New()
      offlinePulseTimer.EventHandler = function()
        pulseOn = not pulseOn
        ctrl.Color = pulseOn and "#C80000" or "#800000"  -- bright red / dim red
      end
      offlinePulseTimer:Start(0.5)
    end
  end
end
--------------------------------------------------------------------------------
-- Set Group States
--------------------------------------------------------------------------------
-- Set group label based on name and optional group_id
function SetGroupLabel(groupId, name)
  local ctrl = Controls["group_label_" .. groupId]
  if not ctrl then return end

  -- Add group ID to label if known
  local groupMeta = state.groupMeta and state.groupMeta[groupId]
  local id = groupMeta and groupMeta.id

  local label = name
  if id then
    label = name .. "\n#" .. tostring(id)
  end

  -- Color lookup
  local color = GROUP_COLORS["Group: " .. groupId]
  if not color then
    ctrl.Color = "#00000000"
    ctrl.String = label
    return
  end

  local r, g, b = table.unpack(color)
  local hex = string.format("#%02X%02X%02X", r, g, b)

  ctrl.String = label
  ctrl.Color = hex
end

-- Utility: Redraw group page if visible
function updateGroupUI(groupId)
  if currentPage == "Groups" then
    RedrawControls() -- forces full re-layout if we're on the Groups page
  end
end

--------------------------------------------------------------------------------
-- Q-SYS Properties / Pages / Color
--------------------------------------------------------------------------------
function GetColor(props)
  return {15,58,83}                  -- plugin tile color in the Q-SYS Inventory
end

function GetPrettyName(props)
  return PluginInfo.Name.." v"..PluginInfo.Version
end

function GetProperties(props)
  local modelChoices = {}
  for modelName, _ in pairs(GigaCoreModels) do
    table.insert(modelChoices, modelName)
  end
  table.sort(modelChoices)

  return {
    {
      Name    = "Model",
      Type    = "enum",
      Choices = modelChoices,
      Value   = "GigaCore 30i"
    },
    {
      Name    = "Dark Mode",
      Type    = "enum",
      Choices = { "Yes", "No" },
      Value   = "No"
    }
  }
end


function GetControls(props)
  local modelProp = props["Model"]
  local modelString = (type(modelProp) == "table") and modelProp.Value or modelProp
  modelString = modelString or "GigaCore 30i"
  -- call the function to get the correct portCount
  local portCount = getPortCount(modelString)
  local c = {}  

  for p = 1, portCount do
     -- Control page (read-only Ports status) 
    c[#c+1] = {
      Name        = "port"..p,
      ControlType = "Button",
      ButtonType  = "Toggle",
      PinStyle    = "Output",
      UserPin     = true,
      IsReadOnly  = true,
    }
    -- Control page (read-only group/vlan color)	
    c[#c+1] = {
      Name         = "port_group_color_"..p,
      ControlType  = "Text",
      TextBoxType  = "ReadOnly",
      PinStyle    = "Output",
      UserPin     = true,	  
      IsReadOnly   = false,
      Value        = "",
    }	
    -- Control page (read-only PoE)	
