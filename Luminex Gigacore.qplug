  }

  c[#c+1] = {
    Name        = "auth_status",
    ControlType = "Text",
    TextBoxType = "ReadOnly",
    PinStyle    = "Output",
    UserPin     = true,
    Value       = "",
	
  }

  c[#c+1] = {
    Name        = "connect",
    ControlType = "Button",
