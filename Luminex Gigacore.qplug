      Name        = "indication"..p,
      ControlType = "Text",
      TextBoxType = "ReadOnly",
      PinStyle    = "Output",
      UserPin     = true,
      Value       = "",
    }
    -- Control page (read-only PoE)	
    c[#c+1] = {
      Name         = "poe_color_"..p,
      ControlType  = "Text",
      TextBoxType  = "ReadOnly",
      PinStyle    = "Output",
      UserPin     = true,	  
      IsReadOnly   = false,
      Value        = "",
    }
    -- Control page (read-only RlinkX)
    c[#c+1] = {
      Name        = "rlinkx_bar_"..p,
      ControlType = "Text",
      TextBoxType = "ReadOnly",
      PinStyle    = "Output",
      UserPin     = true,	  
      IsReadOnly  = false,
      Value       = "",
    }
    -- Control page (read-only display with line split)
    c[#c+1] = {
      Name        = "port_legend_display_"..p,
      ControlType = "Text",
      TextBoxType = "ReadOnly",
      PinStyle    = "Output",
      UserPin     = true,
      IsReadOnly  = true,
      Value       = "",
    }   
	
    -- Port settings page (Enable/Disabled port toggle's)                                                                               -- Enabled
    c[#c+1] = {
      Name        = "port_enable_toggle_"..p,
      ControlType = "Button",
      ButtonType  = "Toggle",
      PinStyle    = "Input",
      UserPin     = true,
    }

    -- Port settings page (editable legend input)
    c[#c+1] = {
      Name        = "port_legend_edit_"..p,
      ControlType = "Text",
      TextBoxType = "Normal",
      PinStyle    = "Output",
      UserPin     = true,
      IsReadOnly  = false,
      Value       = "",
    }
    -- Port settings page (toggle for rlinkX)                                                                                                -- 3 RlinkX
