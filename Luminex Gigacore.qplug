    Size            = {160, 40},
    IsReadOnly      = true,
    Color           = theme.indicatorFill,
    StrokeColor     = theme.strokeColor,
    StrokeWidth     = 0,
    TextColor       = theme.textColor,
    HTextAlign      = "Left",
    VTextAlign      = "Top",
    FontSize        = 11,
    Font            = "Roboto",
	CornerRadius    = 1,
  }

  layout["ip_info"] = {
    Style           = "Indicator",
    Position        = { ipX, ipY },
    Size            = { ipW, ipH },
    IsReadOnly      = true,
    Color           = theme.indicatorFill,
    StrokeColor     = theme.strokeColor,
    StrokeWidth     = 0,
    TextColor       = theme.textColor,
    FontSize        = 11,
    Font            = "Roboto",
    HTextAlign      = "Left",
	CornerRadius    = 1,
  }

  layout["mac_firmware"] = {
    Style           = "Indicator",
    Position        = {macFW_X, macFW_Y},
    Size            = {macFW_W, macFW_H},
    IsReadOnly      = true,
    Color           = theme.indicatorFill,
    StrokeColor     = theme.strokeColor,
    StrokeWidth     = 0,
    TextColor       = theme.textColor,
    FontSize        = 11,
    Font            = "Roboto",
    HTextAlign      = "Left",
	CornerRadius    = 1,
  }

  layout["device_status"] = {
    Style        = "Text",
    Position     = {10, 250},
    Size         = {50, 18},
    IsReadOnly   = true,
    Color        = {0, 0, 0, 0},
    Font         = "Roboto",
    FontSize     = 11,
    TextColor    = {255, 255, 255},
    StrokeWidth  = 0,
	CornerRadius = 6,
    HTextAlign   = "Center",
    VTextAlign   = "Center",
    Legend       = "Status"
  }
end

--------------------------------------------------------------------------------
-- Build Controls Page
--------------------------------------------------------------------------------
function buildControlsPage(layout, gfx, portCount)
  local columns = math.ceil(portCount / 2)
  local btnW, btnH = 66, 44
  local colSpacing = 5
  local rowGap = 60
  local sideMargin = SIDE_MARGIN
  local totalPortsW = columns * btnW + (columns - 1) * colSpacing
  local totalW = totalPortsW + sideMargin * 2
  local totalH = 275
  local topY = 50
  local botY = topY + btnH + rowGap
  local startX = sideMargin
  local portIndex = 1
  local theme = getThemeColors()

  gfx[#gfx+1] = {
    Type        = "Groupbox",
    Fill        = theme.groupboxFill,
    StrokeColor = GROUPBOX_STROKE_COLOR,
    StrokeWidth = GROUPBOX_STROKE_WIDTH,
    Position    = GROUPBOX_POSITION,
    Size        = {totalW + GROUPBOX_EXTRA_PADDING, totalH},
  }

  -- Luminex Logo and Device Info
  local lumCenterX, ipY = drawCommonLogos(gfx)
  defineCommonDeviceInfo(layout, gfx, theme, lumCenterX, ipY + -5)

  -- Draw Ports
  for c = 0, columns-1 do
    if portIndex > portCount then break end
    local xPos = startX + c*(btnW+colSpacing)
    local yPos = topY

    gfx[#gfx+1] = {
      Type = "Rectangle",
      Position = {xPos + 1, yPos + 1},
      Size = {btnW - 2, 88},
      Fill = theme.rectangleFill,
      StrokeColor = {0, 0, 0, 60},
      StrokeWidth = 1,
      CornerRadius = 14
    }

    -- Button for Link State
    layout["port"..portIndex] = {
      Style       = "Button",
	    ButtonStyle = "Toggle",
      ButtonVisualStyle  = "Flat",
      Position    = {xPos, yPos},
      Size        = {btnW, btnH},
      IsReadOnly  = true,
      Color       = LINK_ON,
      OffColor    = LINK_OFF,
      StrokeColor = {100, 100, 100, 120},
      StrokeWidth = 1,
      CornerRadius= 4,
    }

    -- Port Number Text on Top
    gfx[#gfx+1] = {
      Type       = "Text",
      Text       = tostring(portIndex),
      Color      = {200, 200, 200, 255},
      Position   = {xPos, yPos},
      Size       = {btnW, btnH},
      Font       = "Roboto",
      FontSize   = 23,
      HTextAlign = "Center",
	    IsBold     = true,
    }

    -- Draw MemberOf / PoE / Rlinkx small indicators
    defineSinglePort(layout, gfx, portIndex, xPos, yPos, btnW, btnH)

    portIndex = portIndex + 1
    if portIndex > portCount then break end

    -- Bottom row
    xPos = startX + c*(btnW+colSpacing)
    yPos = botY

    gfx[#gfx+1] = {
      Type         = "Rectangle",
      Position     = {xPos + 1, yPos + 1},
      Size         = {btnW - 2, 88},
      Fill         = theme.rectangleFill,
      StrokeColor  = {0, 0, 0, 60},
      StrokeWidth  = 1,
      CornerRadius = 14
    }

    layout["port"..portIndex] = {
      Style       = "Button",
	    ButtonStyle = "Toggle",
      ButtonVisualStyle  = "Flat",
      Position   = {xPos, yPos},
      Size       = {btnW, btnH},
      IsReadOnly = true,
      Color      = LINK_ON,
      OffColor   = LINK_OFF,
      StrokeColor = {100, 100, 100, 120},
      StrokeWidth = 1,                    -- was 2
      CornerRadius= 4,                    -- was 14
    }

    gfx[#gfx+1] = {
      Type      = "Text",
      Text      = tostring(portIndex),
      Color     = {200, 200, 200, 255},
      Position  = {xPos, yPos},
      Size      = {btnW, btnH},
      Font      = "Roboto",
      FontSize  = 23,
      HTextAlign= "Center",
	    IsBold      = true,
    }

    defineSinglePort(layout, gfx, portIndex, xPos, yPos, btnW, btnH)

    portIndex = portIndex + 1
  end
end

-- ========== Port settings page ==========
function buildPortSettingsPage(layout, gfx, props)
  local model = props["Model"] and props["Model"].Value or "GigaCore 30i"
  local portCount = getPortCount(model)
  local rows = 8
  local columns = math.ceil(portCount / rows)

  local toggleW   = 22                   -- Width of the port enable toggle
  local labelW    = 17                   -- Width of the port number label
  local boxW      = 100                  -- Width of the legend edit field
  local rlinkxW   = 22                   -- Width of the RLinkX toggle button
  local poeToggleW = 22                  -- Width of the PoE toggle button
  local dropdownW = 124                  -- Width of the link speed dropdown
  local gap       = 0                    -- Default horizontal spacing between most elements

  -- [Enable Btn] → [Port # Label] → [Legend TextBox] → [RLinkX Toggle] → [PoE Toggle Btn] → [Link Speed Dropdown]
  local colW = labelW + toggleW + boxW + rlinkxW + poeToggleW + dropdownW + (gap * 5)

  -- local colW = toggleW + compactGap + labelW + gap + boxW + gap + rlinkxW + gap + poeToggleW + gap + dropdownW
  local cSpace = colW + 2
  local boxH = 18                        -- Height of all horizontal rows
  local rSpace = 22                      -- Vertical spacing between rows (per port)
  local startX = 2                       -- Starting top-left position for layout columns and rows
  local startY = 50                      -- Starting top-left position for layout columns and rows

  local totalW = columns * cSpace + startX
  local totalH = 275

  local theme = getThemeColors()

  gfx[#gfx+1] = {
    Type        = "Groupbox",
    Fill        = theme.groupboxFill,
    StrokeColor = GROUPBOX_STROKE_COLOR,
    StrokeWidth = GROUPBOX_STROKE_WIDTH,
    Position    = GROUPBOX_POSITION,
    Size        = {totalW + GROUPBOX_EXTRA_PADDING, totalH},
  }

  local lumCenterX, ipY = drawCommonLogos(gfx)
  defineCommonDeviceInfo(layout, gfx, theme, lumCenterX, ipY)

--  -- PoE Bounce Delay Field
--  layout["poe_bounce_delay"] = {
--    Style           = "TextBox",
--    Position        = {379, 250},
--    Size            = {20, 18},
--    FontSize        = 10,
--    Label           = "Bounce (s)",
--    ShowLabel       = true,
--    HTextAlign      = "Center",
--    TextColor       = {255, 255, 255},
--    Color           = theme.indicatorFill,
----    BackgroundColor = {40, 40, 40},
--    CornerRadius    = 3,
--    StrokeWidth     = 1
--  }

  -- Per-port Controls
  local p = 1
  for col = 0, columns - 1 do
    for row = 0, rows - 1 do
      if p > portCount then break end

      local y = startY + row * rSpace
      local x = startX + col * cSpace

      -- Horizontal positioning
      local labelX      = x
      local enableX     = labelX + labelW + gap
      local legendX     = enableX + toggleW + gap
      local rlinkxX     = legendX + boxW + gap
      local poeToggleX  = rlinkxX + rlinkxW + gap
      local speedX      = poeToggleX + poeToggleW + gap

      layout["port_enable_toggle_"..p] = {
        Style         = "Button",
        ButtonStyle   = "Toggle",
        Position      = {enableX - 2, y},
        Size          = {toggleW, boxH},
        FontSize      = 10,
        TextColor     = {255, 255, 255},
        Color         = {30, 200, 60},
        OffColor      = {0, 0, 0},
        CornerRadius  = 2,
        HTextAlign    = "Center",
        VTextAlign    = "Center",
        ButtonVisualStyle   = "Flat",
        Legend        = ""
      }

      gfx[#gfx+1] = {
        Type       = "Text",
        Text       = tostring(p),
        Position   = {labelX, y},
        Size       = {labelW, boxH},
        Font       = "Roboto",
        FontSize   = 11,
        Color      = {180, 255, 255},
        HTextAlign = "Center",
        VTextAlign = "Center"
      }

      layout["port_legend_edit_" .. p] = {
        Style           = "TextBox",
        Position        = {legendX -1, y},
        Size            = {boxW, boxH},
        Font            = "Roboto",
        FontSize        = 11,
        HTextAlign      = "Left",
        TextColor       = {255, 255, 255},
        Color           = {0, 0, 0, 0},
        StrokeWidth     = 1,
        CornerRadius    = 1
      }

      layout["port_rlinkx_toggle_" .. p] = {
        Style         = "Button",
        ButtonStyle   = "Toggle",
        Position      = {rlinkxX, y},
        Size          = {rlinkxW, boxH},
        Color         = {0, 200, 255},
        CornerRadius  = 2,
        OffColor      = {40, 40, 40},
        HTextAlign    = "Center",
        VTextAlign    = "Center",
        ButtonVisualStyle   = "Flat",
        Legend        = ""
      }

      layout["port_poe_toggle_" .. p] = {
        Style             = "Button",
        ButtonStyle       = "Toggle",
        Position          = {poeToggleX, y},
        Size              = {poeToggleW, boxH},
        String            = "",
        Color             = {0, 0, 0, 0},
        CornerRadius      = 2,
        ButtonVisualStyle = "Flat"
      }

      layout["port_speed_dropdown_" .. p] = {
        Style           = "ComboBox",
        Position        = {speedX, y},
        Size            = {dropdownW, boxH},
        Font            = "Roboto",
        FontSize        = 11,
        TextColor       = {255, 255, 255},
        Color           = {20, 24, 40, 180},
        IsReadOnly      = false,
        StrokeWidth     = 1,
        CornerRadius    = 1
      }

      p = p + 1
    end
  end
end

-- ========== Configuration page ==========
function buildConfigurationPage(layout, gfx, props)
  local theme = getThemeColors()

  local totalW  = 475
  local totalH  = 275

  gfx[#gfx+1] = {
    Type        = "Groupbox",
    Fill        = theme.groupboxFill,
    StrokeColor = {0, 0, 0},
    StrokeWidth = 0,
    Position    = {0, 0},
    Size        = {totalW, totalH},
  }

  local lumCenterX, ipY = drawCommonLogos(gfx)
  defineCommonDeviceInfo(layout, gfx, theme, lumCenterX, ipY)

  local labelX   = 30
  local inputX   = 110
  local rowY     = 90
  local rowGap   = 40
  local boxW     = 140
  local boxH     = 24
  local labelW   = 70

  local connectX = 270
  local btnW     = 120
  local btnH     = 30

  -- Label: IP Address
  gfx[#gfx+1] = {
    Type       = "Text",
    Text       = "IP Address",
    Position   = {labelX, rowY + 0},
    Size       = {labelW, boxH},
    Font       = "Roboto",
    FontSize   = 10,
    Color      = theme.labelGray,
    HTextAlign = "Right",
    VTextAlign = "Center"
  }

  layout["ip_addr"] = {
    Style           = "TextBox",
    Position        = {inputX, rowY + 0},
    Size            = {boxW, boxH},
    Font            = "Roboto",
    FontSize        = 14,
    HTextAlign      = "Center",
    Color           = {0, 0, 0, 0},
    TextColor       = {255, 255, 255},
  }

  layout["connect"] = {
    Legend           = "Connect",
    Style            = "Button",
    ButtonStyle      = "Momentary",
    Color            = {0, 255, 0},
    OffColor         = theme.buttonOffColor,
    Position         = {connectX, rowY},
    Size             = {btnW, btnH},
    Font             = "Roboto",
    FontSize         = 13,
    HTextAlign       = "Center",
  }

  -- Label: Username
  gfx[#gfx+1] = {
    Type       = "Text",
    Text       = "Username",
    Position   = {labelX, rowY + rowGap},
    Size       = {labelW, boxH},
    Font       = "Roboto",
    FontSize   = 10,
    TextColor  = {255, 255, 255},
    Color      = theme.labelGray,
    HTextAlign = "Right",
    VTextAlign = "Center"
  }

  layout["auth_username"] = {
    Style           = "TextBox",
    Position        = {inputX, rowY + rowGap},
    Size            = {boxW, boxH},
    Font            = "Roboto",
    FontSize        = 14,
    HTextAlign      = "Center",
    Color           = {0, 0, 0, 0},
    TextColor       = {255, 255, 255},
  }

  layout["identify"] = {
    Legend           = "Identify",
    Style            = "Button",
    ButtonStyle      = "Momentary",
    Color            = {0, 150, 255},
    OffColor         = {30, 30, 30},
    Position         = {connectX, rowY + rowGap},
    Size             = {btnW, btnH},
    Font             = "Roboto",
    FontSize         = 13,
    HTextAlign       = "Center",
  }

  -- Label: Password
  gfx[#gfx+1] = {
    Type       = "Text",
    Text       = "Password",
    Position   = {labelX, rowY + rowGap * 2},
    Size       = {labelW, boxH},
    Font       = "Roboto",
    FontSize   = 10,
    Color      = theme.labelGray,
    HTextAlign = "Right",
    VTextAlign = "Center"
  }

  layout["auth_password"] = {
    Style           = "TextBox",
    IsPassword      = true,
    Position        = {inputX, rowY + rowGap * 2},
    Size            = {boxW, boxH},
    Font            = "Roboto",
    FontSize        = 14,
    HTextAlign      = "Center",
    Color           = {0, 0, 0, 0},
    TextColor       = {255, 255, 255},
  }

  -- Auth status box
  layout["auth_status"] = {
    Style        = "Text",
    Position     = {connectX, rowY + rowGap * 2},
    Size         = {btnW, boxH},
    Font         = "Roboto",
    FontSize     = 11,
    TextColor    = {255, 255, 255},
    StrokeWidth  = 0,
    Color        = {0, 0, 0, 0},
    HTextAlign   = "Center",
    VTextAlign   = "Center",
    IsReadOnly   = true,
    Legend       = "Auth Status"
  }
end

-- ========== Group/Trunk settings page ==========
function buildGroupTrunkSettingsPage(layout, gfx, props)
  local theme = getThemeColors()

  gfx[#gfx+1] = {
    Type        = "Groupbox",
    Fill        = theme.groupboxFill,
    StrokeColor = GROUPBOX_STROKE_COLOR,
    StrokeWidth = GROUPBOX_STROKE_WIDTH,
    Position    = GROUPBOX_POSITION,
    Size        = {540, 275}  -- Static groupbox, not dynamic
  }

  local lumCenterX, ipY = drawCommonLogos(gfx)
  defineCommonDeviceInfo(layout, gfx, theme, lumCenterX, ipY)

  -- Constants
  local boxW, boxH     = 96, 36
  local gapX, gapY     = 10, 12
  local startX, startY = 10, 50
  local stdCols        = 5
  local extCols        = 4

  state.groupMeta = state.groupMeta or {}
  state.groupNames = state.groupNames or {}

  -- Determine max group ID
  local maxGroupId = 40
  for i, _ in pairs(state.groupNames) do
    if i > maxGroupId then maxGroupId = i end
  end

  local customIndex = 0
  for i = 1, maxGroupId do
    local x, y

    if i <= 20 then
      local col = (i - 1) % stdCols
      local row = math.floor((i - 1) / stdCols)
      x = startX + col * (boxW + gapX)
      y = startY + row * (boxH + gapY)
    elseif state.groupMeta[i] then
      local col = customIndex % extCols
      local row = math.floor(customIndex / extCols)
      x = startX + stdCols * (boxW + gapX) + col * (boxW + gapX)
      y = startY + row * (boxH + gapY)
      customIndex = customIndex + 1
    end

    if x and y then
      local name = state.groupNames[i] or ("Group " .. i)
      local groupData = state.groupMeta[i]
      local groupIdVal = groupData and groupData.id

      local colorTable = GROUP_COLORS["Group: " .. i]
      local hexColor = colorTable and string.format("#%02X%02X%02X", table.unpack(colorTable)) or "#202020"

      layout["group_id_badge_" .. i] = {
        Style           = "Text",
        Position        = {x - 9, y - 3},
        Size            = {9, 9},
        FontSize        = 7,
        Font            = "Roboto",
        TextColor       = {255, 255, 255},
        Color           = theme.indicatorFill,
        CornerRadius    = 2,
        StrokeWidth     = 0,
        IsReadOnly      = true,
        HTextAlign      = "Right",
        VTextAlign      = "Center",
        String          = groupIdVal and tostring(groupIdVal) or ""
      }

      layout["group_label_" .. i] = {
        Style           = "Text",
        Position        = {x, y},
        Size            = {boxW, boxH},
        IsReadOnly      = true,
        Multiline       = true,
        FontSize        = 12,
        Font            = "Roboto",
        Color           = "#00000000",
        TextColor       = {255, 255, 255},
        BackgroundColor = hexColor,
        StrokeWidth     = 0,
        CornerRadius    = 6,
        HTextAlign      = "Center",
        VTextAlign      = "Center",
        String          = name
      }
    end
  end
end

