      Name        = "port_rlinkx_toggle_"..p,
      ControlType = "Button",
      ButtonType  = "Toggle",
      PinStyle    = "Input",
      UserPin     = true,
    }
    -- Port settings page (Momentary for PoE Bounce)                                                                                                                 -- Bounce
    c[#c+1] = {
      Name        = "port_bounce_btn_"..p,
      ControlType = "Button",
      ButtonType  = "Momentary",
      PinStyle    = "Input",
      UserPin     = true,
    }
    -- Port settings page (dropdown for Port speed)	
    c[#c+1] = {
      Name        = "port_speed_dropdown_"..p,
      ControlType = "Text",
      TextBoxType = "ComboBox",
      PinStyle    = "Input",
      UserPin     = true,
      Choices     = {
        "Auto",
        "Disabled",
        "1 Gbps",
        "100 Mbps (Full-duplex)",
        "100 Mbps (Half-duplex)",
        "10 Mbps (Full-duplex)",
        "10 Mbps (Half-duplex)"
      },
      Value = "Auto"
    }	
	
  end
-- Group Page
  for i = 1, 20 do
    c[#c+1] = {
      Name         = "group_label_"..i,
      ControlType  = "Text",
      TextBoxType  = "ReadOnly",
      PinStyle     = "None",
      UserPin      = false,
      IsReadOnly   = true,
      Value        = ""
    }
  end
--  SHOW ON ALL PAGES
  c[#c+1] = {
    Name        = "device_name",
    ControlType = "Text",
    TextBoxType = "ReadOnly",
    PinStyle    = "Output",
    UserPin     = true,
    Value       = "",
    MultiLine   = true, 	
  }
  
  c[#c+1] = {
    Name        = "device_description",
    TextBoxType = "ReadOnly",
    PinStyle    = "Output",
    UserPin     = true,
