  return c
end


function RectifyProperties(props)
  log("RectifyProperties called")
  local modelString = props["Model"]
  local darkModeChoice = props["Dark Mode"]

  state.portCount = getPortCount(modelString)

  props.RebuildGUI = true  -- ensures layout is rebuilt with new theme
  return props
end


function updateCombinedIP()                 -- Rebuilds the string "ip/prefix(mode)" and updates "actual_ip" text
  local combined = storedIP
  if storedPrefix ~= "" then
    combined = combined .. "/" .. storedPrefix
  end
  if storedIPmode ~= "" then
    combined = combined .. "(" .. storedIPmode .. ")"
  end
end
--------------------------------------------------------------------------------
-- Build the dynamic pages
--------------------------------------------------------------------------------
function GetPages(props)
  local modelProp = props["Model"]
  local modelString = (type(modelProp) == "table") and modelProp.Value or "GigaCore 30i"
  local pages = {}

  table.insert(pages, { name = modelString })             -- use the model name for the page directly
  table.insert(pages, { name = "Port settings" })
  table.insert(pages, { name = "Groups" })  
  table.insert(pages, { name = "Configuration" })  
--  table.insert(pages, { name = "Testing" })

  return pages
end
--------------------------------------------------------------------------------
-- Build the 30-port (etc.) "Controls" page
--------------------------------------------------------------------------------
local function defineSinglePort(layout, gfx, portIndex, xPos, yPos, w, h)
  local gap       = 2           -- vertical gap between blocks
  local btnH      = h           -- main port button height
  local poeH      = 8
  local groupH    = 14
  local legendH   = 28
  local rlinkxH   = 20
  local nextY = yPos
  nextY = nextY + btnH + gap

  -- Legend box (with split text)
  layout["port_legend_display_"..portIndex] = {
    Style        = "Text",
    Position     = {xPos + 4, nextY - 1},
    Size         = {w - 8, legendH},
    FontSize     = 11,
    Font         = "Roboto",
    Color        = {0, 0, 0, 0},
    StrokeWidth  = 0,
    StrokeColor  = {0, 0, 0, 0},
    TextColor    = {255, 255, 255},
    HTextAlign   = "Center",
    VTextAlign   = "Top",
    IsReadOnly   = true,
  }

  nextY = nextY + legendH + gap

  layout["port_group_color_"..portIndex] = {
    Style           = "Text",
    Position        = {xPos + 4, nextY - 4},
    Size            = {w - 8, groupH},
    IsReadOnly      = true,
    FontSize        = 11,
    Color           = {0, 0, 0, 0},
    StrokeWidth     = 0,
    StrokeColor     = {0, 0, 0, 0},
	Font            = "Roboto",
    HTextAlign      = "Center",
    VTextAlign      = "Center",
	BackgroundColor = {25, 28, 42, 220},
	CornerRadius    = 6,
  }

  nextY = nextY + groupH + gap
  
 layout["poe_color_"..portIndex] = {
    Style        = "Text",
    Position     = {xPos + (w - 14) // 2, yPos - poeH + 3},
    Size         = {14, poeH},
    FontSize     = 1,
    IsReadOnly   = true,
    Color        = {0, 0, 0, 0},
    TextColor    = {0, 0, 0, 0},	
    StrokeWidth  = 0,
    CornerRadius = 2,	
    HTextAlign   = "Center",
    VTextAlign   = "Center",	
  }
  
  layout["rlinkx_bar_"..portIndex] = {
    Style        = "Text",
    Position     = {xPos + 15, yPos + h - 5},
    Size         = {w - 30, 3},
    FontSize     = 1,
    IsReadOnly   = true,
    Color        = {0, 0, 0, 0},
    TextColor    = {0, 0, 0, 0},
    StrokeWidth  = 0,
    CornerRadius = 2,
    HTextAlign   = "Center",
    VTextAlign   = "Center",
  }
end

  --  Luminex logo
local function drawCommonLogos(gfx)
  local lumX, lumY   = 5, 5
  local lumW, lumH   = 119, 36
  gfx[#gfx+1] = {
    Type     = "Svg",
    Image    = LogoLuminex,
    Position = { lumX, lumY },
    Size     = { lumW, lumH },
  }
  
  local lumCenterX   = lumX + (lumW / 2) 
  local lumBottomY = lumY + lumH 
  
  return lumCenterX, lumBottomY
end


